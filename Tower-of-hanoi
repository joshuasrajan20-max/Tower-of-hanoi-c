// Tower of hanoi.


#include<stdio.h>

void tower(int n,char s,char h,char d){
    if(n == 1){
    printf("%c ---> %c\n", s, d);
    return;
}
    tower(n-1,s,d,h);
    printf("%c ---> %c\n",s,d);
    tower(n-1,h,s,d);
    return;
}

int main(){
    int n;
    printf("Enter number of disk: ");
    scanf("%d",&n);

    printf("All Steps for solving Tower of Hanoi:-\n");
    tower(n,'A','B','C');
    return 0;
}
